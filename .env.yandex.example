# Настройки для Yandex Cloud (Object Storage)
# Раскомментируйте и настройте переменные для использования Yandex Cloud

# Включить использование Yandex Cloud (True/False)
USE_YANDEX_CLOUD=False

# Доступные ключи для Yandex Object Storage (S3-совместимый)
YANDEX_CLOUD_ACCESS_KEY_ID=your_access_key_id
YANDEX_CLOUD_SECRET_ACCESS_KEY=your_secret_access_key
YANDEX_CLOUD_BUCKET_NAME=your_bucket_name
YANDEX_CLOUD_ENDPOINT_URL=https://storage.yandexcloud.net

# Опционально: CDN URL для ускорения загрузки
# YANDEX_CLOUD_CDN_URL=https://your-cdn-domain.ru

# Путь к водяному знаку (по умолчанию media/watermark.png)
# WATERMARK_PATH=/path/to/watermark.png

# Временная директория для обработки файлов (по умолчанию media_temp)
# MEDIA_TEMP_DIR=/path/to/temp/dir
